	"settings": {
		"i18n-ally.extract.autoDetect": true,
		"i18n-ally.extract.ignored": [
			"string >= 14",
			"string.alphanumeric >= 5"
		],
		"i18n-ally.extract.ignoredByFiles": {
			"components/NewsArticleCreateButton.vue": [
				"[",
				"`",
